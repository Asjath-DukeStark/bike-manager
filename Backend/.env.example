# Environment Variables — Copy this to .env and fill in your values

PORT=4000

# IMPORTANT: Change this to a long, random secret string in production!
JWT_SECRET=change-this-to-a-very-long-random-secret-string

# Session duration for JWT tokens (e.g., 7d, 24h, 30d)
JWT_EXPIRES_IN=30d

# Admin credentials (the only login for this app)
ADMIN_USERNAME=admin
ADMIN_PIN=1234

# Frontend URL for CORS — update this to your Vercel URL in production
# e.g. FRONTEND_URL=https://bike-manager.vercel.app
FRONTEND_URL=http://localhost:3000
