# Frontend Environment Variables
# Copy this file to .env.local for local development
# Set VITE_API_URL in your Vercel project settings for production

# Local development — points to the local Express backend
VITE_API_URL=http://localhost:4000

# Production — set this to your Railway backend URL in Vercel dashboard
# VITE_API_URL=https://your-backend.up.railway.app
